<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9">

    <com.example.javagps4gbs.items.BuildingMapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:layout_marginBottom="160dp" />

    <TextView
        android:id="@+id/tvFloorLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Floor 1"
        android:textColor="#000"
        android:background="#AAFFFFFF"
        android:padding="8dp"
        android:layout_margin="12dp"
        android:elevation="6dp"
        android:layout_gravity="top|end"/>

    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#E9EDF2"
        android:padding="8dp"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btnLeft"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="←"
                android:backgroundTint="#DDE3E9"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnForward"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="↑"
                android:layout_marginHorizontal="8dp"
                android:backgroundTint="#DDE3E9"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnRight"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="→"
                android:backgroundTint="#DDE3E9" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btnAddNode"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Add Node"
                android:layout_height="wrap_content"
                android:backgroundTint="#CFE5FF" />

            <Button
                android:id="@+id/btnSetStart"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Set Start"
                android:layout_marginHorizontal="6dp"
                android:backgroundTint="#CFE5FF" />

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Delete"
                android:layout_height="wrap_content"
                android:backgroundTint="#FFD1D1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btnZoomIn"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Zoom +"
                android:layout_height="wrap_content"
                android:backgroundTint="#E1F5C4" />

            <Button
                android:id="@+id/btnZoomOut"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Zoom -"
                android:layout_marginHorizontal="6dp"
                android:backgroundTint="#E1F5C4" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Save Map"
                android:layout_height="wrap_content"
                android:backgroundTint="#B2E0B2" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnAddFloor"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Add Floor"
                android:backgroundTint="#C9D6FF" />

            <Button
                android:id="@+id/btnPrevFloor"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Prev Floor"
                android:layout_marginHorizontal="6dp"
                android:backgroundTint="#C9D6FF" />

            <Button
                android:id="@+id/btnNextFloor"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Next Floor"
                android:layout_height="wrap_content"
                android:backgroundTint="#C9D6FF" />
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
